{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Gen clangd db",
			"type": "shell",
			"command": "scripts/clang-tools/gen_compile_commands.py",
			"options": {
				"cwd": "${workspaceFolder}/linux",
				"env": {
					"PATH": "${env:HOME}/Code/python3.12/bin:${env:PATH}"
				}
			},
			"detail": "compile commands 生成"
		},
		{
			"label": "Copy clangd db",
			"type": "shell",
			"command": "mv linux/compile_commands.json .vscode/build",
			"dependsOn": [
				"Gen clangd db"
			],
			"dependsOrder": "sequence",
			"options": {
				"cwd": "${workspaceFolder}",
				"env": {
					"PATH": "${env:HOME}/Code/python3.12/bin:${env:PATH}"
				}
			},
			"detail": "compile commands 拷贝",
			"problemMatcher": []
		},
		{
			"label": "Disasm ELF",
			"type": "shell",
			"command": "riscv64-linux-gnu-objdump -dx linux/vmlinux > vmlinux.disasm",
			"options": {
				"cwd": "${workspaceFolder}",
				"env": {
					"PATH": "${env:HOME}/Code/python3.12/bin:${env:PATH}",
					"ARCH": "riscv",
					"CROSS_COMPILE": "riscv64-linux-gnu-"
				}
			},
			"detail": "反汇编"
		},
		{
			"label": "defconfig",
			"type": "shell",
			"command": "make defconfig",
			"options": {
				"cwd": "${workspaceFolder}/linux",
				"env": {
					"PATH": "${env:HOME}/Code/python3.12/bin:${env:PATH}",
					"ARCH": "riscv",
					"CROSS_COMPILE": "riscv64-linux-gnu-"
				}
			},
			"detail": "编译 defconfig"
		},
		{
			"label": "menuconfig",
			"type": "shell",
			"command": "make menuconfig",
			"options": {
				"cwd": "${workspaceFolder}/linux",
				"env": {
					"PATH": "${env:HOME}/Code/python3.12/bin:${env:PATH}",
					"ARCH": "riscv",
					"CROSS_COMPILE": "riscv64-linux-gnu-"
				}
			},
			"detail": "编译 menuconfig",
			"problemMatcher": [
				"$nvcc"
			]
		},
		{
			"label": "gen rootfs",
			"type": "shell",
			"command": "find . | cpio -o --format=newc | gzip > ../rootfs.cpio.gz",
			"options": {
				"cwd": "${workspaceFolder}/rootfs",
				"env": {
					"PATH": "${env:HOME}/Code/python3.12/bin:${env:PATH}",
					"ARCH": "riscv",
					"CROSS_COMPILE": "riscv64-linux-gnu-"
				}
			},
			"detail": "编译根文件系统",
			"problemMatcher": [
				"$gcc"
			]
		},
		{
			"label": "Compile RISC-V Linux Kernel",
			"type": "shell",
			"command": "make -j$(nproc)",
			"options": {
				"cwd": "${workspaceFolder}/linux",
				"env": {
					"PATH": "${env:HOME}/Code/python3.12/bin:${env:PATH}",
					"ARCH": "riscv",
					"CROSS_COMPILE": "riscv64-linux-gnu-"
				}
			},
			"dependsOn": [
				"menuconfig",
				"gen rootfs"
			],
			"dependsOrder": "sequence",
			"detail": "编译 RISCV 内核",
			"problemMatcher": [
				"$gcc"
			]
		},
		{
			"label": "qemu boot",
			"type": "shell",
			"options": {
				"cwd": "${workspaceFolder}",
				"env": {
					"PATH": "${env:HOME}/Code/python3.12/bin:${env:PATH}"
				}
			},
			"command": "qemu-system-riscv64",
			"args": [
				"-machine",
				"virt",
				"-nographic",
				"-smp",
				"1",
				"-m",
				"256M",
				"-kernel",
				"linux/arch/riscv/boot/Image",
				"-initrd",
				"rootfs.cpio.gz",
				"-append",
				"\"console=ttyS0 root=/dev/ram rw\""
			],
			"detail": "配置 qemu boot",
			"problemMatcher": [
				"$nvcc"
			]
		},
		{
			"label": "qemu boot debug",
			"type": "shell",
			"options": {
				"cwd": "${workspaceFolder}"
			},
			"command": "qemu-system-riscv64",
			"args": [
				"-machine",
				"virt",
				"-nographic",
				"-smp",
				"1",
				"-m",
				"256M",
				"-kernel",
				"linux/arch/riscv/boot/Image",
				"-initrd",
				"rootfs.cpio.gz",
				"-append",
				"\"console=ttyS0 root=/dev/ram rw\"",
				"-s",
				"-S"
			],
			"detail": "配置 qemu boot debug"
		},
		{
			"label": "git submodule update",
			"detail": "git submodule 更新",
			"command": "git submodule update --remote --recursive",
			"type": "shell",
			"options": {
				"cwd": "${workspaceFolder}"
			},
			"problemMatcher": [
				"$nvcc"
			]
		},
		{
			"label": "Compile OpenSBI",
			"detail": "编译 OpenSBI",
			"command": "make PLATFORM=generic CROSS_COMPILE=riscv64-linux-gnu- DEBUG=1",
			"type": "shell",
			"options": {
				"cwd": "${workspaceFolder}/opensbi"
			},
			"problemMatcher": [
				"$nvcc"
			]
		},
		{
			"label": "Compile UEFI",
			"detail": "编译 UEFI",
			"command": "source edksetup.sh && make -C BaseTools && build -a RISCV64 -t GCC -p OvmfPkg/RiscVVirt/RiscVVirtQemu.dsc -b DEBUG",
			"type": "shell",
			"options": {
				"cwd": "${workspaceFolder}/edk2",
				"env": {
					"PATH": "${env:HOME}/Code/python3.12/bin:${env:PATH}",
					"GCC_RISCV64_PREFIX": "riscv64-linux-gnu-"
				}
			},
			"problemMatcher": [
				"$nvcc"
			]
		},
		{
			"label": "uefi boot",
			"type": "shell",
			"options": {
				"cwd": "${workspaceFolder}",
				"env": {
					"PATH": "${env:HOME}/Code/python3.12/bin:${env:PATH}"
				}
			},
			"command": "qemu-system-riscv64 -nographic -machine virt -m 1G -bios opensbi/build/platform/generic/firmware/fw_dynamic.bin -drive if=pflash,format=raw,unit=0,file=edk2/Build/RiscVVirtQemu/DEBUG_GCC/FV/RISCV_VIRT_CODE.fd,readonly=on -drive if=pflash,format=raw,unit=1,file=edk2/Build/RiscVVirtQemu/DEBUG_GCC/FV/RISCV_VIRT_VARS.fd -drive file=esp.img,format=raw,id=hd0 -device virtio-blk-device,drive=hd0",
			"args": [],
			"detail": "uefi boot 内核",
			"problemMatcher": [
				"$nvcc"
			]
		},
		{
			"label": "update esp.img",
			"detail": "更新 esp.img",
			"command": "sudo mount esp.img /mnt && sudo cp -r esp/* /mnt && sudo umount /mnt ",
			"type": "shell",
			"options": {
				"cwd": "${workspaceFolder}"
			},
			"problemMatcher": [
				"$nvcc"
			]
		},
	]
}
