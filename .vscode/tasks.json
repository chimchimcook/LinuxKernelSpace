{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Gen clangd db",
			"type": "shell",
			"command": "scripts/clang-tools/gen_compile_commands.py",
			"options": {
				"cwd": "${workspaceFolder}/linux",
				"env": {
					"PATH": "${env:HOME}/Code/python3.12/bin:${env:PATH}"
				}
			},
			"detail": "compile commands 生成"
		},
		{
			"label": "Copy clangd db",
			"type": "shell",
			"command": "mv linux/compile_commands.json .vscode/build",
			"dependsOn": [
				"Gen clangd db"
			],
			"dependsOrder": "sequence",
			"options": {
				"cwd": "${workspaceFolder}",
				"env": {
					"PATH": "${env:HOME}/Code/python3.12/bin:${env:PATH}"
				}
			},
			"detail": "compile commands 拷贝",
			"problemMatcher": []
		},
		{
			"label": "Disasm ELF",
			"type": "shell",
			"command": "riscv64-linux-gnu-objdump -dx linux/vmlinux > vmlinux.disasm",
			"options": {
				"cwd": "${workspaceFolder}",
				"env": {
					"PATH": "${env:HOME}/Code/python3.12/bin:${env:PATH}",
					"ARCH": "riscv",
					"CROSS_COMPILE": "riscv64-linux-gnu-"
				}
			},
			"detail": "反汇编"
		},
		{
			"label": "defconfig",
			"type": "shell",
			"command": "make defconfig",
			"options": {
				"cwd": "${workspaceFolder}/linux",
				"env": {
					"PATH": "${env:HOME}/Code/python3.12/bin:${env:PATH}",
					"ARCH": "riscv",
					"CROSS_COMPILE": "riscv64-linux-gnu-"
				}
			},
			"detail": "编译 defconfig"
		},
		{
			"label": "menuconfig",
			"type": "shell",
			"command": "make menuconfig",
			"options": {
				"cwd": "${workspaceFolder}/linux",
				"env": {
					"PATH": "${env:HOME}/Code/python3.12/bin:${env:PATH}",
					"ARCH": "riscv",
					"CROSS_COMPILE": "riscv64-linux-gnu-"
				}
			},
			"detail": "编译 menuconfig",
			"problemMatcher": [
				"$nvcc"
			]
		},
		{
			"label": "gen rootfs",
			"type": "shell",
			"command": "find . | cpio -o --format=newc | gzip > ../rootfs.cpio.gz",
			"options": {
				"cwd": "${workspaceFolder}/rootfs",
				"env": {
					"PATH": "${env:HOME}/Code/python3.12/bin:${env:PATH}",
					"ARCH": "riscv",
					"CROSS_COMPILE": "riscv64-linux-gnu-"
				}
			},
			"detail": "编译根文件系统",
			"problemMatcher": [
				"$gcc"
			]
		},
		{
			"label": "Compile RISC-V Linux Kernel",
			"type": "shell",
			"command": "make -j$(nproc)",
			"options": {
				"cwd": "${workspaceFolder}/linux",
				"env": {
					"PATH": "${env:HOME}/Code/python3.12/bin:${env:PATH}",
					"ARCH": "riscv",
					"CROSS_COMPILE": "riscv64-linux-gnu-"
				}
			},
			"detail": "编译 RISCV 内核",
			"problemMatcher": [
				"$gcc"
			]
		},
		{
			"label": "qemu boot",
			"type": "shell",
			"options": {
				"cwd": "${workspaceFolder}",
				"env": {
					"PATH": "${env:HOME}/Code/python3.12/bin:${env:PATH}"
				}
			},
			"command": "qemu-system-riscv64",
			"args": [
				"-machine",
				"virt",
				"-nographic",
				"-smp",
				"1",
				"-m",
				"256M",
				"-kernel",
				"linux/arch/riscv/boot/Image",
				// "-initrd",
				// "rootfs.cpio.gz",
				"-device",
				"virtio-blk-device,drive=hd0",
				"-drive",
				"file=esp.img,format=raw,id=hd0",
				"-device",
				"virtio-blk-device,drive=hd1",
				"-drive",
				"file=rootfs.ext4,format=raw,id=hd1",
				"-append",
				// "\"console=ttyS0 root=/dev/ram rw\""
				"\"console=ttyS0 root=/dev/vdb rw\""
			],
			"detail": "配置 qemu boot",
			"problemMatcher": [
				"$nvcc"
			]
		},
		{
			"label": "qemu boot debug",
			"type": "shell",
			"options": {
				"cwd": "${workspaceFolder}"
			},
			"command": "qemu-system-riscv64",
			"args": [
				"-machine",
				"virt",
				"-nographic",
				"-smp",
				"1",
				"-m",
				"256M",
				"-kernel",
				"linux/arch/riscv/boot/Image",
				"-initrd",
				"rootfs.cpio.gz",
				"-append",
				"\"console=ttyS0 root=/dev/ram rw\"",
				"-s",
				"-S"
			],
			"detail": "配置 qemu boot debug"
		},
		{
			"label": "git submodule update",
			"detail": "git submodule 更新",
			"command": "git submodule update --remote --recursive",
			"type": "shell",
			"options": {
				"cwd": "${workspaceFolder}"
			},
			"problemMatcher": [
				"$nvcc"
			]
		},
		{
			"label": "Compile OpenSBI",
			"detail": "编译 OpenSBI",
			"command": "make PLATFORM=generic CROSS_COMPILE=riscv64-linux-gnu- DEBUG=1",
			"type": "shell",
			"options": {
				"cwd": "${workspaceFolder}/opensbi"
			},
			"problemMatcher": [
				"$nvcc"
			]
		},
		{
			"label": "Compile UEFI",
			"detail": "编译 UEFI",
			"command": "source edksetup.sh && make -C BaseTools && build -a RISCV64 -t GCC -p OvmfPkg/RiscVVirt/RiscVVirtQemu.dsc -b DEBUG",
			"type": "shell",
			"options": {
				"cwd": "${workspaceFolder}/edk2",
				"env": {
					"PATH": "${env:HOME}/Code/python3.12/bin:${env:PATH}",
					"GCC_RISCV64_PREFIX": "riscv64-linux-gnu-"
				}
			},
			"problemMatcher": [
				"$nvcc"
			]
		},
		{
			"label": "uefi boot",
			"type": "shell",
			"options": {
				"cwd": "${workspaceFolder}",
				"env": {
					"PATH": "${env:HOME}/Code/python3.12/bin:${env:PATH}"
				}
			},
			"command": "qemu-system-riscv64 -nographic -machine virt,pflash0=pflash0,pflash1=pflash1,acpi=off -m 1G -smp 1 -bios opensbi/build/platform/generic/firmware/fw_dynamic.bin -blockdev node-name=pflash0,driver=file,read-only=on,filename=edk2/Build/RiscVVirtQemu/DEBUG_GCC/FV/RISCV_VIRT_CODE.fd -blockdev node-name=pflash1,driver=file,filename=edk2/Build/RiscVVirtQemu/DEBUG_GCC/FV/RISCV_VIRT_VARS.fd -drive file=esp.img,format=raw,id=hd0 -device virtio-blk-device,drive=hd0 -serial mon:stdio -drive file=rootfs.ext4,format=raw,id=hd1 -device virtio-blk-device,drive=hd1",
			"args": [],
			"detail": "uefi boot 内核",
			"problemMatcher": [
				"$nvcc"
			]
		},
		{
			"label": "update esp.img",
			"detail": "更新 esp.img",
			"command": "cp linux/arch/riscv/boot/Image esp/ && sudo mount esp.img mnt && sudo cp -r esp/* mnt && sudo umount mnt ",
			"type": "shell",
			"options": {
				"cwd": "${workspaceFolder}"
			},
			"problemMatcher": [
				"$nvcc"
			],
			// "dependsOn": "gen rootfs"
		},
		{
			"label": "uefi boot debug",
			"type": "shell",
			"options": {
				"cwd": "${workspaceFolder}",
				"env": {
					"PATH": "${env:HOME}/Code/python3.12/bin:${env:PATH}"
				}
			},
			"command": "qemu-system-riscv64 -nographic -machine virt,pflash0=pflash0,pflash1=pflash1,acpi=off -m 1G -smp 1 -bios opensbi/build/platform/generic/firmware/fw_dynamic.bin -blockdev node-name=pflash0,driver=file,read-only=on,filename=edk2/Build/RiscVVirtQemu/DEBUG_GCC/FV/RISCV_VIRT_CODE.fd -blockdev node-name=pflash1,driver=file,filename=edk2/Build/RiscVVirtQemu/DEBUG_GCC/FV/RISCV_VIRT_VARS.fd -drive file=esp.img,format=raw,id=hd0 -device virtio-blk-device,drive=hd0 -serial mon:stdio -drive file=rootfs.ext4,format=raw,id=hd1 -device virtio-blk-device,drive=hd1 -S -s",
			"args": [],
			"detail": "uefi boot debug 内核",
			"problemMatcher": [
				"$nvcc"
			]
		},
		{
			"label": "mkfs.ext4",
			"command": "dd if=/dev/zero of=rootfs.ext4 bs=1M count=64 && mkfs.ext4 rootfs.ext4 && sudo mount rootfs.ext4 mnt && sudo cp -r rootfs/* mnt/ && sudo umount mnt",
			"type": "shell",
			"options": {
				"cwd": "${workspaceFolder}",
				"env": {
					"PATH": "${env:HOME}/Code/python3.12/bin:${env:PATH}"
				}
			},
			"detail": "制作 ext4 rootfs文件",
			"problemMatcher": [
				"$gcc"
			]
		}
	]
}
